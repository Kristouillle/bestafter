---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path: string;
  fullBleed?: boolean;
}

const { title, description, path, fullBleed = false } = Astro.props;

const navigation = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
  { href: "/donations", label: "Donations" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-shell">
        <div class="site-header-inner">
          <a class="brand" href="/">
            BestAfter:
            <small>Open source for public good</small>
          </a>
          <nav class="nav" aria-label="Primary navigation">
            {
              navigation.map((item) => (
                <a href={item.href} aria-current={path === item.href ? "page" : undefined}>
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </div>
    </header>

    <main>
      {fullBleed ? <slot /> : <div class="site-shell"><slot /></div>}
    </main>

    <footer class="site-footer">
      <div class="site-shell">
        <div class="site-footer-inner">
          BestAfter builds nonprofit open source software that stays accessible, maintainable, and useful.
        </div>
      </div>
    </footer>
  </body>
</html>
