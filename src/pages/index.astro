---
import MainLayout from "../layouts/MainLayout.astro";

export const prerender = true;
---

<MainLayout
  title="BestAfter: yesterday"
  description="Personal site for nonprofit open source software projects, support, and donations."
  path="/"
  fullBleed={true}
>
  <section class="hero">
    <div class="hero-smudge" aria-hidden="true"></div>
    <div class="hero-fade" aria-hidden="true"></div>
    <div class="site-shell hero-inner">
      <div class="hero-copy">
        <h1>For the love of the game</h1>
        <p class="lead">
          i do shit i wanna do and publish it for free. that's it.
          i really miss when the web wasn't just a big ugly shopping mall.
          hope what i make is useful to you.
        </p>
      </div>

      <div class="hero-mark" aria-hidden="true">
        <span>OPEN</span>
        <span>SOURCE</span>
        <span>NONPROFIT</span>
        <span>SOFTWARE</span>
      </div>
    </div>
  </section>

  <section class="scan-story" data-scan-story data-stage="black">
    <div class="site-shell">
      <div class="scan-story-grid">
        <div class="scan-copy">
          <article class="scan-step" data-scan-step="black">
            <span class="scan-index">.01</span>
            <h2>chaos & noise</h2>
            <p>
              that's all there is out there.  that's all they want us to consume.
              <br />
              <br />
              another social media platform, another "innovation" to distract us.
              <br />
              <br />
              another platform to monetize our attention and time.
              <br />
              <br />
              i don't even want to bring people together, i just want to build for building's sake.
            </p>
          </article>

          <article class="scan-step" data-scan-step="white">
            <span class="scan-index">.02</span>
            <h2>find some joy</h2>
            <p>
              what do you want to build? what brings YOU joy?
              <br />
              <br />
              ever see a sunset and just think "i wanna capture that"?
              <br />
              <br />
              fix a personal pain point or build a fun tamagotchi that looks like your dog.
              <br />
              <br />
              that's what we're here for.
            </p>
          </article>

          <article class="scan-step" data-scan-step="red">
            <span class="scan-index">.03</span>
            <h2>now do it</h2>
            <p>
              build something just for you.  share it with the world if you want, but don't worry about the algorithm or the ads or the engagement.
              <br />
              <br />
              i'm begging you to not put ads, no in app purchases, no tracking, no analytics.
              <br />
              <br />
              just build for the joy of it.
              <br />
              <br />
              you'd be surpised at the fulfillment you can get from building something just for yourself and keeping it opensourced.
            </p>
          </article>
        </div>

        <div class="scan-visual">
          <div class="scan-frame">
            <video
              class="scan-video scan-video-black"
              src="/videos/blackscan.webm"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-hidden="true"
            ></video>
            <video
              class="scan-video scan-video-white"
              src="/videos/whitescan.webm"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-hidden="true"
            ></video>
            <video
              class="scan-video scan-video-red"
              src="/videos/redscan.webm"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-hidden="true"
            ></video>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="anti-hero">
    <div class="anti-hero-fade" aria-hidden="true"></div>
    <div class="site-shell anti-hero-inner">
      <div class="anti-hero-mark" aria-hidden="true">
        <span>KEEP IT</span>
        <span>SMALL</span>
        <span>KEEP IT</span>
        <span>ALIVE</span>
      </div>

      <div class="anti-hero-copy">
        <h2>Not everything needs to become a platform.</h2>
        <p class="lead">
          some things should stay personal, legible, and open.
          software can be weird, specific, and useful without turning into a pitch deck.
        </p>
      </div>
    </div>
  </section>

  <script is:inline>
    const scanStory = document.querySelector("[data-scan-story]");
    const scanSteps = Array.from(document.querySelectorAll("[data-scan-step]"));
    const scanVideos = Array.from(document.querySelectorAll(".scan-video"));

    if (scanStory && scanSteps.length) {
      const setStage = (stage) => {
        scanStory.dataset.stage = stage;
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

          if (visible) {
            setStage(visible.target.getAttribute("data-scan-step") || "black");
          }
        },
        {
          rootMargin: "-30% 0px -30% 0px",
          threshold: [0.2, 0.45, 0.7]
        }
      );

      scanSteps.forEach((step) => observer.observe(step));
    }

    if (scanVideos.length) {
      const tryPlay = (video) => {
        video.muted = true;
        video.defaultMuted = true;
        video.loop = true;
        const playPromise = video.play();
        if (playPromise && typeof playPromise.catch === "function") {
          playPromise.catch(() => {});
        }
      };

      const syncToFirst = () => {
        const [master, ...rest] = scanVideos;
        if (!master) {
          return;
        }

        rest.forEach((video) => {
          if (Math.abs(video.currentTime - master.currentTime) > 0.08) {
            video.currentTime = master.currentTime;
          }
        });
      };

      scanVideos.forEach((video) => {
        video.addEventListener("loadeddata", () => tryPlay(video), { once: true });
      });

      const [master] = scanVideos;
      if (master) {
        master.addEventListener("timeupdate", syncToFirst);
      }

      scanVideos.forEach(tryPlay);
    }
  </script>
</MainLayout>
